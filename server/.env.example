# Gmail: correo que envía (ej. mi.correo@gmail.com)
GMAIL_USER=

# Contraseña de aplicación de Gmail (no la contraseña normal).
# Crear en: Cuenta Google → Seguridad → Verificación en 2 pasos → Contraseñas de aplicaciones
GMAIL_APP_PASSWORD=

# Opcional: puerto del servidor (por defecto 3001)
# PORT=3001

# --- Playlists y OAuth Spotify ---
# Spotify: crear app en https://developer.spotify.com/dashboard
# Redirect URI: Spotify NO permite "localhost". Usar la IP de loopback (RFC 8252, §7.3):
#   http://127.0.0.1:3001/api/spotify/callback
# Para vincular desde el MÓVIL en la misma WiFi: añade también en Spotify → Redirect URIs:
#   http://TU_IP_LOCAL:3001/api/spotify/callback   (ej. http://192.168.1.10:3001/api/spotify/callback)
# El servidor usa la IP del request si no defines SPOTIFY_REDIRECT_URI.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3001/api/spotify/callback

# URL del frontend para redirigir tras OAuth. Si no la defines, en móvil se usa la IP de la petición.
# En PC: http://localhost:5173  |  En móvil en LAN: http://TU_IP:5173 (ej. http://192.168.1.10:5173)
# FRONTEND_URL=http://localhost:5173

# Opcional: interfaz del servidor. Por defecto 0.0.0.0 = accesible desde la red local (móvil).
# HOST=0.0.0.0

# --- OAuth 2.0 YouTube (API de datos / acceso usuario) ---
# En Google Cloud Console: crear credenciales "ID de cliente" (aplicación web).
# En "URIs de redirección autorizados" añade:
#   http://127.0.0.1:3001/api/youtube/callback
# Para vincular desde el MÓVIL en la misma WiFi, añade también:
#   http://TU_IP_LOCAL:3001/api/youtube/callback   (ej. http://192.168.1.10:3001/api/youtube/callback)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://127.0.0.1:3001/api/youtube/callback

# Clave API para acceso público (playlists por URL). Crear en https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# Opcional: ruta a browser.json de ytmusicapi (autenticación por navegador).
# Por defecto: server/ytmusicapi/browser.json. Ver docs/YT_MUSIC.md y https://ytmusicapi.readthedocs.io/en/stable/setup/browser.html
# YTMUSIC_BROWSER_JSON=./ytmusicapi/browser.json

# --- Producción: NO uses este archivo en el servidor ---
# En producción (Railway, Render, etc.) las variables se configuran en el panel del host,
# no en .env. Mismas claves, valores con URLs públicas. Ver docs/CHECKLIST_PRODUCCION.md.
# Ejemplo en Railway: SPOTIFY_REDIRECT_URI=https://pato-production.up.railway.app/api/spotify/callback
#                    FRONTEND_URL=https://pa-to.netlify.app
